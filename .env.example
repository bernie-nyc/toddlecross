# Toddlecross Configuration
# Copy this file to '.env' and fill in your live API keys for local testing.

# Django Settings
DEBUG=True
SECRET_KEY=django-insecure-generate-a-secure-random-string-for-production-here
ALLOWED_HOSTS=localhost,127.0.0.1

# SQLite Database (default for local development)
DATABASE_URL=sqlite:///db.sqlite3

# Google SSO OAuth2 Configuration
# You must obtain client ID and secret from the Google Cloud Console (APIs & Services > Credentials)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Toddleapp API Configuration
# Base API URL: https://ap-southeast-1-production-apis.toddleapp.com/
TODDLE_API_BASE_URL=https://ap-southeast-1-production-apis.toddleapp.com/
TODDLE_API_KEY=your_toddleapp_api_key_here

# Veracross API Configuration
VERACROSS_API_BASE_URL=https://api.veracross.com/your_school_name/v3/
VERACROSS_TOKEN_URL=https://accounts.veracross.com/your_school_name/oauth/token
VERACROSS_CLIENT_ID=your_veracross_client_id
VERACROSS_CLIENT_SECRET=your_veracross_client_secret

# Toddle LTI Credentials (for integration launch)
TODDLE_LTI_ISSUER_URL=your_toddle_lti_issuer_url
TODDLE_LTI_CLIENT_ID=your_toddle_lti_client_id
TODDLE_LTI_LOGIN_URL=your_toddle_lti_login_url
TODDLE_LTI_KEYSET_URL=your_toddle_lti_keyset_url
TODDLE_LTI_TOKEN_URL=your_toddle_lti_token_url
TODDLE_LTI_DEPLOYMENT_ID=your_toddle_lti_deployment_id

# PostgreSQL Database (uncomment/override to replace default SQLite for container deployments)
# DATABASE_URL=postgres://toddlecross:toddlecross_secure_pwd@db:5432/toddlecross

# Default Superuser Credentials (optional, used by entrypoint.sh on initialization)
SUPERUSER_USERNAME=admin
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PASSWORD=adminpassword
